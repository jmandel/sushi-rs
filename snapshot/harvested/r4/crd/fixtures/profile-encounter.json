          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/davinci-crd/StructureDefinition/profile-encounter"
            ],
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-hierarchy",
