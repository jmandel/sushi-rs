              "http://hl7.org/fhir/us/davinci-crd/StructureDefinition/profile-appointment-with-order",
              "http://hl7.org/fhir/us/davinci-crd/StructureDefinition/profile-appointment-no-order"
            ]
          }
        ],
        "mustSupport": true
