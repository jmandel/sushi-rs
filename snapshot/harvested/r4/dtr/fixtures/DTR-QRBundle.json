{
  "resourceType": "StructureDefinition",
  "id": "DTR-QRBundle",
  "url": "http://hl7.org/fhir/us/davinci-dtr/StructureDefinition/DTR-QRBundle",
  "name": "DTRQuestionnaireResponseBundle",
  "title": "DTR Questionnaire Response Bundle",
  "status": "active",
  "description": "This profile represents the Bundle created by EHRs for transmission of a QuestionnaireResponse and associated resources to PAS, for claim submission, etc..",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Bundle",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Bundle",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Bundle",
        "path": "Bundle",
        "constraint": [
          {
            "key": "dtrb-2",
            "severity": "error",
            "human": "The first resource in bundle must be a QuestionnaireResponse.",
            "expression": "entry.first().resource.is(QuestionnaireResponse)",
            "source": "http://hl7.org/fhir/us/davinci-dtr/StructureDefinition/DTR-QRBundle"
          }
        ]
      },
      {
        "id": "Bundle.type",
        "path": "Bundle.type",
        "patternCode": "collection"
      },
      {
        "id": "Bundle.entry",
        "path": "Bundle.entry",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "resource"
            }
          ],
          "rules": "open",
          "description": "Slice different resources included in the bundle"
        },
        "min": 1
      },
      {
        "id": "Bundle.entry:questionnaireResponse",
        "path": "Bundle.entry",
        "sliceName": "questionnaireResponse",
        "short": "SHALL have one and only one QuestionnaireResponse",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:questionnaireResponse.resource",
        "path": "Bundle.entry.resource",
        "min": 1,
        "type": [
          {
            "code": "QuestionnaireResponse",
            "profile": [
              "http://hl7.org/fhir/us/davinci-dtr/StructureDefinition/dtr-questionnaireresponse"
            ]
          }
        ]
      }
    ]
  }
}
