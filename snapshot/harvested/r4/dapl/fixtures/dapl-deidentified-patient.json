        "min": 0,
        "max": "0",
        "mustSupport": false
      },
      {
        "id": "Patient.address.postalCode",
        "path": "Patient.address.postalCode",
        "short": "ZipCode must be included in the profile",
        "min": 1,
        "max": "1",
        "constraint": [
          {
            "key": "dapl-potalCode-1",
            "severity": "error",
            "human": "De-identified Zipcodes can contain first 3 digits followed by 00 in the last two digits or have to be masked with 00000. If the extended ZipCode format is used the resulting format should be #####-####.",
            "expression": "$this.matches('^[0-9]{3}[0]{2}(-[0-9]{4})?$')",
            "xpath": "f:matches(postalCode,'^[0-9]{3}[0]{2}(-[0-9]{4})?$')"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.address.postalCode.extension:dataAbsentReason",
