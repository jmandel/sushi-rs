        "min": 0,
        "max": "1",
        "type": [
          {
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/elementdefinition-type-must-support",
                "valueBoolean": true
              }
            ],
            "code": "dateTime"
          },
          {
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/elementdefinition-type-must-support",
                "valueBoolean": true
              }
            ],
            "code": "boolean"
          }
        ],
        "constraint": [
          {
            "key": "dapl-date-1",
            "severity": "error",
            "human": "All dateTime data elements should be truncated to a year only for de-identified resources.",
            "expression": "$this is dateTime implies $this.toString().length() = 4"
          },
          {
            "key": "dapl-date-1a",
            "severity": "error",
            "human": "All dateTime data elements should have valid year > 1900",
            "expression": "$this is dateTime implies $this.toString() >= '1900'"
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Patient.address",
        "path": "Patient.address",
        "short": "Included only to support zip code",
        "min": 1,
        "max": "1",
        "mustSupport": true
