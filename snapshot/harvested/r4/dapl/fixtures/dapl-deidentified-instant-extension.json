        ],
        "constraint": [
          {
            "key": "dapl-datetime-1",
            "severity": "error",
            "human": "All dateTime data elements should be truncated to a year only for de-identified resources.",
            "expression": "$this is DateTime implies $this.toString().length() = 4"
          },
          {
            "key": "dapl-datetime-1a",
            "severity": "error",
            "human": "All dateTime data elements should have valid year > 1900",
            "expression": "$this is DateTime implies $this.toString() >= '1900'"
          }
        ]
      }
    ]
