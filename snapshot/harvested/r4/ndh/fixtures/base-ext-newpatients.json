          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-newpatients-characteristics"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Extension.url",
        "path": "Extension.url",
        "fixedUri": "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-newpatients"
      },
      {
        "id": "Extension.value[x]",
        "path": "Extension.value[x]",
        "max": "0"
      }
    ]
  }
}
