    {
      "identity": "ndh-to-plannet-location",
      "name": "NDH to Plan-Net Location Mapping",
      "uri": "http://hl7.org/fhir/us/davinci-pdex-plan-net",
      "comment": "Maps NDH Location profile to the Plan-Net Location profile, noting elements not present in Plan-Net."
    }
  ],
