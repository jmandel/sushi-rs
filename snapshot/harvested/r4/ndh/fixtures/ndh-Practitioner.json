        "id": "Practitioner.qualification.code",
        "path": "Practitioner.qualification.code",
        "binding": {
          "extension": [
            {
              "url": "http://hl7.org/fhir/tools/StructureDefinition/additional-binding",
              "valueString": "Qualification",
              "extension": [
                {
                  "url": "key",
                  "valueId": "nucc"
                },
                {
                  "url": "purpose",
                  "valueCode": "extensible"
                },
                {
                  "url": "valueSet",
                  "valueCanonical": "http://hl7.org/fhir/us/ndh/ValueSet/HealthcareIndividualTaxonomyVS"
                },
                {
                  "url": "documentation",
                  "valueMarkdown": "The code that identifies the license, or certification held by the individual.  For example, a practitioner may have a medical license, and a nursing license."
                },
                {
                  "url": "shortDoco",
                  "valueString": "The code that identifies license, or certification; regulated authorization to practice."
                }
              ]
            },
            {
              "url": "http://hl7.org/fhir/tools/StructureDefinition/additional-binding",
              "extension": [
                {
                  "url": "key",
                  "valueId": "credentials"
                },
                {
                  "url": "purpose",
                  "valueCode": "extensible"
                },
                {
                  "url": "valueSet",
                  "valueCanonical": "http://hl7.org/fhir/us/ndh/ValueSet/FaCeTcredentialVS"
                },
                {
                  "url": "documentation",
                  "valueMarkdown": "The code that identifies the credential held by the individual.  For example, a practitioner may have a Fellowship in cardiology from the American College of Cardiology."
                },
                {
                  "url": "shortDoco",
                  "valueString": "The code that identifies the credential; evidence that supports or proves an authorization."
                }
              ]
            }
          ],
          "strength": "example",
          "description": "Specific qualification the practitioner has to provide a service.",
          "valueSet": "http://terminology.hl7.org/ValueSet/v2-2.7-0360"
        }
