        "min": 1,
        "mapping": [
          {
            "identity": "ndh-to-plannet-organizationaffiliation",
            "map": "OrganizationAffiliation.meta.lastUpdated",
            "comment": ", is required in NDH"
          }
        ]
      },
      {
        "id": "OrganizationAffiliation.extension",
        "path": "OrganizationAffiliation.extension",
        "slicing": {
