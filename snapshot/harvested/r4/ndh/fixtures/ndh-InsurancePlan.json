{
  "resourceType": "StructureDefinition",
  "id": "ndh-InsurancePlan",
  "url": "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-InsurancePlan",
  "name": "NdhInsurancePlan",
  "title": "NDH InsurancePlan Profile",
  "status": "active",
  "description": "This profile enables NDH to publish normalized insurance product and plan details, including coverage, network relationships, and administration, so users can compare options and accurately match plans to participating providers and service areas; it adds verification and identifier-status extensions and uses ValueSet bindings to normalize product type, coverage type, benefit type, and plan type classifications.",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "ndh-to-plannet-insuranceplan",
      "name": "NDH to Plan-Net InsurancePlan Mapping",
      "uri": "http://hl7.org/fhir/us/davinci-pdex-plan-net",
      "comment": "Maps NDH InsurancePlan profile to the Plan-Net InsurancePlan profile, noting elements not present in Plan-Net."
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "InsurancePlan",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/InsurancePlan",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "InsurancePlan",
        "path": "InsurancePlan",
        "constraint": [
          {
            "key": "network-or-NatlDirwork",
            "severity": "error",
            "human": "If an insuranceplan does not define a network, then each plan must define one",
            "expression": "network.exists() or coverage.network.exists() or plan.network.exists()",
            "source": "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-InsurancePlan"
          },
          {
            "key": "plan-type-is-distinct",
            "severity": "error",
            "human": "Each InsurancePlan.plan should have a distinct plan.type.",
            "expression": "plan.type.coding.code.isDistinct()",
            "source": "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-InsurancePlan"
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-insuranceplan",
            "map": "InsurancePlan",
            "comment": "Top-level mapping from NDH to Plan-Net"
          }
        ]
      },
