{
  "resourceType": "StructureDefinition",
  "id": "ndh-Group",
  "url": "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Group",
  "name": "NdhGroup",
  "title": "NDH Group",
  "status": "active",
  "description": "This profile enables NDH to represent multidisciplinary provider groups as directory entities so consumers can discover team-based programs and services and understand the practitioner and practitioner-role membership that supports coordinated care delivery; it adds extensions for location and endpoint references, verification, artifact description, and effective period, and uses ValueSet-constrained group coding to standardize program/service classification.",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "ndh-to-plannet-group",
      "name": "There is no mapping between NDH and Plan-Net for Group structure, since Plan-Net does not have a direct equivalent.",
      "uri": "http://hl7.org/fhir/us/davinci-pdex-plan-net",
      "comment": "Plan-Net does not have a direct equivalent for NDH Group."
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "Group",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Group",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Group.meta.lastUpdated",
        "path": "Group.meta.lastUpdated",
        "min": 1
      },
      {
        "id": "Group.extension",
        "path": "Group.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Group.extension:location",
        "path": "Group.extension",
        "sliceName": "location",
        "short": "Network coverage area",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-location-reference"
            ]
          }
        ]
      },
      {
        "id": "Group.extension:endpoint",
        "path": "Group.extension",
        "sliceName": "endpoint",
        "short": "Endpoint Reference",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-endpoint-reference"
            ]
          }
        ]
      },
      {
        "id": "Group.extension:service-offered",
        "path": "Group.extension",
        "sliceName": "service-offered",
        "short": "Service Offered",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-service-offered"
            ]
          }
        ]
      },
      {
        "id": "Group.extension:verification-status",
        "path": "Group.extension",
        "sliceName": "verification-status",
        "short": "Group Verification Status",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-verification-status"
            ]
          }
        ]
      },
      {
        "id": "Group.extension:artifact-description",
        "path": "Group.extension",
        "sliceName": "artifact-description",
        "short": "Group Description",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/StructureDefinition/artifact-description"
            ]
          }
        ]
      },
      {
        "id": "Group.extension:artifact-effectivePeriod",
        "path": "Group.extension",
        "sliceName": "artifact-effectivePeriod",
        "short": "Group Effective Period",
        "min": 0,
