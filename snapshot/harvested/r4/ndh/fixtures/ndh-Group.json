        "path": "Group.active",
        "min": 1,
        "fixedBoolean": true,
        "mustSupport": true
      },
      {
        "id": "Group.type",
        "path": "Group.type",
        "fixedCode": "practitioner"
      },
      {
        "id": "Group.actual",
        "path": "Group.actual",
        "fixedBoolean": true
      },
      {
        "id": "Group.code",
        "path": "Group.code",
        "short": "NDH Group type (Care Team Category)",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/ndh/ValueSet/NDHCareTeamCategoryVS"
