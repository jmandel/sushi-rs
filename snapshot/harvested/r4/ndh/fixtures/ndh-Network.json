{
  "resourceType": "StructureDefinition",
  "id": "ndh-Network",
  "url": "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Network",
  "name": "NdhNetwork",
  "title": "NDH Network Profile",
  "status": "active",
  "description": "This profile enables NDH to represent payer and provider network structures as computable directory data so users can determine network participation, geographic coverage, and organizational relationships that affect access and coverage decisions; it adds extensions for coverage-area references, organization period, and verification, and uses ValueSet bindings to standardize network type and key identifier semantics.",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "ndh-to-plannet-network",
      "name": "NDH to Plan-Net Network Mapping",
      "uri": "http://hl7.org/fhir/us/davinci-pdex-plan-net",
      "comment": "Maps NDH Network profile to the Plan-Net Network profile, noting elements not present in Plan-Net."
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "Organization",
  "baseDefinition": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization|6.1.0",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Organization",
        "path": "Organization",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network",
            "comment": "Top-level mapping from NDH to Plan-Net"
          }
        ]
      },
      {
        "id": "Organization.meta.lastUpdated",
        "path": "Organization.meta.lastUpdated",
        "min": 1,
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.meta.lastUpdated",
            "comment": ", is required in NDH"
          }
        ]
      },
      {
        "id": "Organization.extension",
        "path": "Organization.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Organization.extension:location",
        "path": "Organization.extension",
        "sliceName": "location",
        "short": "Network coverage area",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-location-reference"
            ]
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.extension[location-reference]",
            "comment": ", recommended in Plan-Net and optional in NDH"
          }
        ]
      },
      {
        "id": "Organization.extension:organization-period",
        "path": "Organization.extension",
        "sliceName": "organization-period",
        "short": "Valid time period for this Network",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/StructureDefinition/organization-period|4.0.1"
            ]
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Not in Plan-Net",
            "comment": ", NDH-specific"
          }
        ]
      },
      {
        "id": "Organization.extension:verification-status",
        "path": "Organization.extension",
        "sliceName": "verification-status",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-verification-status"
            ]
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Not in Plan-Net",
            "comment": ", NDH-specific"
          }
        ]
      },
      {
        "id": "Organization.identifier",
        "path": "Organization.identifier",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.identifier"
          }
        ]
      },
      {
        "id": "Organization.identifier.extension:identifier-status",
        "path": "Organization.identifier.extension",
        "sliceName": "identifier-status",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-identifier-status"
            ]
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Not in Plan-Net",
            "comment": ", NDH-specific"
          }
        ]
      },
      {
        "id": "Organization.identifier.use",
        "path": "Organization.identifier.use",
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/identifier-use|4.0.1"
        }
      },
      {
        "id": "Organization.identifier.type",
        "path": "Organization.identifier.type",
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/ValueSet/identifier-type|4.0.1"
        }
      },
      {
        "id": "Organization.identifier.assigner",
        "path": "Organization.identifier.assigner",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Organization"
            ]
          }
        ]
      },
      {
        "id": "Organization.identifier:NPI",
        "path": "Organization.identifier",
        "sliceName": "NPI",
        "max": "0"
      },
      {
        "id": "Organization.identifier:CLIA",
        "path": "Organization.identifier",
        "sliceName": "CLIA",
        "max": "0"
      },
      {
        "id": "Organization.active",
        "path": "Organization.active",
        "fixedBoolean": true,
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.active",
            "comment": ", required in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.type",
        "path": "Organization.type",
        "min": 1,
        "max": "1",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/us/ndh/ValueSet/NetworkTypeVS"
        },
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.type",
            "comment": ", required in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.name",
        "path": "Organization.name",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.name",
            "comment": ", required in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.address.line",
        "path": "Organization.address.line",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.address.line",
            "comment": ", optional in Plan-Net and optional in NDH"
          }
        ]
      },
      {
        "id": "Organization.address.city",
        "path": "Organization.address.city",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.address.city",
            "comment": ", optional in Plan-Net and optional in NDH"
          }
        ]
      },
      {
        "id": "Organization.address.state",
        "path": "Organization.address.state",
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/core/ValueSet/us-core-usps-state|6.1.0"
        },
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.address.state",
            "comment": ", optional in Plan-Net and recommended in NDH"
          }
        ]
      },
      {
        "id": "Organization.address.postalCode",
        "path": "Organization.address.postalCode",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.address.postalCode",
            "comment": ", optional in Plan-Net and optional in NDH"
          }
        ]
      },
      {
        "id": "Organization.address.country",
        "path": "Organization.address.country",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.address.country",
            "comment": ", optional in Plan-Net and optional in NDH"
          }
        ]
      },
      {
        "id": "Organization.partOf",
        "path": "Organization.partOf",
        "short": "The organization that manages this network",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Organization"
            ],
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-hierarchy",
                "valueBoolean": true
              }
            ]
          }
        ],
        "mustSupport": true,
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.partOf",
            "comment": ", required in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.contact",
        "path": "Organization.contact",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.contact",
            "comment": ", optional in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.contact.name",
        "path": "Organization.contact.name",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.contact.name",
            "comment": ", optional in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.contact.telecom",
        "path": "Organization.contact.telecom",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.contact.telecom",
            "comment": ", optional in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.contact.address",
        "path": "Organization.contact.address",
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.contact.address",
            "comment": ", optional in Plan-Net and NDH"
          }
        ]
      },
      {
        "id": "Organization.contact.address.state",
        "path": "Organization.contact.address.state",
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/core/ValueSet/us-core-usps-state|6.1.0"
        },
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.contact.address.state",
            "comment": ", optional in Plan-Net and extensible in NDH"
          }
        ]
      },
      {
        "id": "Organization.endpoint",
        "path": "Organization.endpoint",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Endpoint"
            ]
          }
        ],
        "mustSupport": true,
        "mapping": [
          {
            "identity": "ndh-to-plannet-network",
            "map": "Network.endpoint",
            "comment": ", using NDH Endpoint Profile"
          }
        ]
      }
    ]
  }
}
