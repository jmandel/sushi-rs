  "mapping": [
    {
      "identity": "ndh-to-plannet-practitionerrole",
      "name": "NDH to Plan-Net PractitionerRole Mapping",
      "uri": "http://hl7.org/fhir/us/davinci-pdex-plan-net",
      "comment": "Maps NDH PractitionerRole profile to the Plan-Net PractitionerRole profile, noting elements not present in Plan-Net."
    }
  ],
