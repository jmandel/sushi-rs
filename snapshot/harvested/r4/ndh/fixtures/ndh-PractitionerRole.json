      {
        "id": "PractitionerRole.organization",
        "path": "PractitionerRole.organization",
        "short": "Organization where the role is available",
        "definition": "The organization where this role is available",
        "comment": "Some relationships (represented as PractitionerRoles) that may exist between practitioners and organizations include:\n - A practitioner may act as a pediatrician when associated with an organization that runs a family clinic.  PractitionerRole.organization would represent the family clinic.\n - The same practitioner may act as a physician when providing physicals for an athletics department at a school.  PractitionerRole.organization would represent the school.\n - A practitioner may perform coumadin anticoagulation services for a clinic run by a health system.   PractitionerRole.organization would represent the coumadin clinic.\n - A practitioner may act as an inpatient pharmacist reviewing and dispensing medications.  PractitionerRole.organization would represent the hospital pharmacy.\n - A practitioner may perform medication management and adherence services for an internal medicine clinic.  PractitionerRole.organization would represent the internal medicine clinic.\n - A practitioner is part of a payer's network such as a preferred provider organization (PPO), or health maintenance organizations (HMO)).  \nPractitionerRole.organization would represent the payer's network.\nEach of the examples above, would be represented as different PractitionerRole instances, each with a different values for PractitionerRole.organization.",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/ndh/StructureDefinition/ndh-Organization"
            ]
          }
        ],
        "mapping": [
          {
            "identity": "ndh-to-plannet-practitionerrole",
            "map": "PractitionerRole.organization"
          }
        ]
