{
  "resourceType": "StructureDefinition",
  "id": "base-ext-dynamicRegistration",
  "url": "http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-dynamicRegistration",
  "name": "DynamicRegistration",
  "title": "NDH Dynamic Registration",
  "status": "active",
  "description": "This extension enables NDH to convey dynamic client-registration capabilities for trust-framework participation, using sub-extensions for trust profile and version and an extensible binding to TrustProfileVS to standardize runtime registration signaling; it is used in Endpoint.",
  "fhirVersion": "4.0.1",
  "kind": "complex-type",
  "abstract": false,
  "context": [
    {
      "expression": "Endpoint",
      "type": "element"
    }
  ],
  "type": "Extension",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Extension",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Extension",
        "path": "Extension",
        "short": "NDH Dynamic Registration",
        "definition": "This extension enables NDH to convey dynamic client-registration capabilities for trust-framework participation, using sub-extensions for trust profile and version and an extensible binding to TrustProfileVS to standardize runtime registration signaling; it is used in Endpoint."
      },
      {
        "id": "Extension.extension:trustProfile",
        "path": "Extension.extension",
        "sliceName": "trustProfile",
        "min": 0,
        "max": "1"
      },
      {
        "id": "Extension.extension:trustProfile.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:trustProfile.url",
        "path": "Extension.extension.url",
        "fixedUri": "trustProfile"
      },
      {
