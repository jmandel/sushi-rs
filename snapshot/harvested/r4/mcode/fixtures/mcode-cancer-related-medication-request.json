          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-procedure-intent"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "MedicationRequest.extension:normalizationBasis",
        "path": "MedicationRequest.extension",
        "sliceName": "normalizationBasis",
        "min": 0,
        "max": "1",
