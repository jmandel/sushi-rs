{
  "resourceType": "StructureDefinition",
  "id": "mcode-human-specimen",
  "extension": [
    {
      "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-fmm",
      "valueInteger": 1
    }
  ],
  "url": "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-human-specimen",
  "name": "HumanSpecimen",
  "title": "Human Specimen Profile",
  "status": "active",
  "description": "A specimen taken from a Patient for the purpose of oncology-related testing. The profile includes extensions to specify a more precise body site and an identifier of source body structure at that site (for example, a tumor identifier).",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 v2 Mapping"
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "Specimen",
  "baseDefinition": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-specimen",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Specimen.identifier",
        "path": "Specimen.identifier",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "type"
            }
          ],
          "rules": "open",
          "description": "Slicing by identifier.type"
        },
        "mustSupport": true
      },
      {
        "id": "Specimen.identifier:bodyStructureIdentifier",
        "path": "Specimen.identifier",
        "sliceName": "bodyStructureIdentifier",
        "short": "An identifier associating the specimen with a identified body structure, such as a tumor with a tumor identifier.",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Identifier",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-body-structure-identifier"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Specimen.identifier:bodyStructureIdentifier.type",
        "path": "Specimen.identifier.type",
        "mustSupport": true
      },
      {
        "id": "Specimen.identifier:bodyStructureIdentifier.value",
        "path": "Specimen.identifier.value",
        "mustSupport": true
      },
      {
        "id": "Specimen.status",
        "path": "Specimen.status",
        "mustSupport": true
      },
      {
        "id": "Specimen.type",
        "path": "Specimen.type",
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-human-specimen-type-vs"
        }
      },
      {
        "id": "Specimen.subject",
        "path": "Specimen.subject",
        "definition": "The patient associated with this specimen.",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-cancer-patient"
            ]
          }
        ]
      },
      {
        "id": "Specimen.collection",
        "path": "Specimen.collection",
        "mustSupport": true
      },
      {
        "id": "Specimen.collection.bodySite",
        "path": "Specimen.collection.bodySite",
        "mustSupport": true
      },
      {
        "id": "Specimen.collection.bodySite.extension",
        "path": "Specimen.collection.bodySite.extension",
        "mustSupport": true
      },
      {
        "id": "Specimen.collection.bodySite.extension:locationQualifier",
        "path": "Specimen.collection.bodySite.extension",
        "sliceName": "locationQualifier",
        "short": "General location qualifier (excluding laterality) for this bodySite",
        "definition": "General location qualifier (excluding laterality) for this bodySite",
        "min": 0,
        "max": "*",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-body-location-qualifier"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Specimen.collection.bodySite.extension:lateralityQualifier",
        "path": "Specimen.collection.bodySite.extension",
        "sliceName": "lateralityQualifier",
        "short": "Laterality qualifier for this bodySite",
        "definition": "Laterality qualifier for this bodySite",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-laterality-qualifier"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
