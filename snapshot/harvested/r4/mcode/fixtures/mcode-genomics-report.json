        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-human-specimen"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "DiagnosticReport.result",
        "path": "DiagnosticReport.result",
        "mustSupport": true
      },
      {
