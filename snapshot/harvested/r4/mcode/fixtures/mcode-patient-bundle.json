{
  "resourceType": "StructureDefinition",
  "id": "mcode-patient-bundle",
  "extension": [
    {
      "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-fmm",
      "valueInteger": 1
    }
  ],
  "url": "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-patient-bundle",
  "name": "MCODEPatientBundle",
  "title": "mCODE Patient Bundle Profile",
  "status": "active",
  "description": "A collection of data for an mCODE cancer patient.",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 v2 Mapping"
    },
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "cda",
      "uri": "http://hl7.org/v3/cda",
      "name": "CDA (R2)"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "Bundle",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Bundle",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Bundle.type",
        "path": "Bundle.type",
        "patternCode": "collection"
      },
      {
        "id": "Bundle.timestamp",
        "path": "Bundle.timestamp",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry",
        "path": "Bundle.entry",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "resource"
            }
          ],
          "rules": "open",
          "description": "Slicing based on the resource type"
        },
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.resource",
        "path": "Bundle.entry.resource",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:cancerPatient",
        "path": "Bundle.entry",
        "sliceName": "cancerPatient",
        "short": "Cancer Patient",
        "definition": "The Cancer Patient whose data is included in the bundle.",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:cancerPatient.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Patient",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-cancer-patient"
            ]
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeObservations",
        "path": "Bundle.entry",
        "sliceName": "mcodeObservations",
        "short": "FHIR Observation Resources, if they exist for the patient, including but not limited to: CancerDiseaseStatus, CancerStage (TNM and non-TNM), Comorbidities, ECOGPerformanceStatus, GenomicRegionStudied, GenomicVariant, KarnofskyPerformanceStatus, TumorMarkerTest, TumorSize, and USCoreVitalSigns.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeObservations.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Observation"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeConditions",
        "path": "Bundle.entry",
        "sliceName": "mcodeConditions",
        "short": "FHIR Condition Resources, if they exist for the patient, including but not limited to: PrimaryCancerCondition, SecondaryCancerCondition, and HistoryOfMetastaticCancer.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeConditions.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Condition"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeMedicationAdministrations",
        "path": "Bundle.entry",
        "sliceName": "mcodeMedicationAdministrations",
        "short": "FHIR Medication Administration Resources, if they exist for the patient, including but not limited to: CancerRelatedMedicationAdministration.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeMedicationAdministrations.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "MedicationAdministration"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeMedicationRequests",
        "path": "Bundle.entry",
        "sliceName": "mcodeMedicationRequests",
        "short": "FHIR Medication Request Resources, if they exist for the patient, including but not limited to: CancerRelatedMedicationRequest.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeMedicationRequests.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "MedicationRequest"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeDiagnosticReports",
        "path": "Bundle.entry",
        "sliceName": "mcodeDiagnosticReports",
        "short": "FHIR Diagnostic Report Resources, if they exist for the patient, including but not limited to: GenomicsReport.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeDiagnosticReports.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "DiagnosticReport"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeSpecimens",
        "path": "Bundle.entry",
        "sliceName": "mcodeSpecimens",
        "short": "FHIR Specimen Resources, if they exist for the patient, including but not limited to: HumanSpecimen.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeSpecimens.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Specimen"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeProcedures",
        "path": "Bundle.entry",
        "sliceName": "mcodeProcedures",
        "short": "FHIR Procedure Resources, if they exist for the patient, including but not limited to: CancerRelatedSurgicalProcedure and RadiotherapyCourseSummary.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeProcedures.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Procedure"
          }
        ]
      },
      {
        "id": "Bundle.entry:mcodeBodyStructures",
        "path": "Bundle.entry",
        "sliceName": "mcodeBodyStructures",
        "short": "FHIR BodyStructure Resources, if they exist for the patient, including but not limited to: RadiotherapyVolume and Tumor.",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:mcodeBodyStructures.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "BodyStructure"
          }
        ]
      }
    ]
  }
}
