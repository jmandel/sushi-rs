{
  "resourceType": "StructureDefinition",
  "id": "mcode-tumor",
  "extension": [
    {
      "url": "http://hl7.org/fhir/StructureDefinition/structuredefinition-fmm",
      "valueInteger": 3
    }
  ],
  "url": "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-tumor",
  "name": "Tumor",
  "title": "Tumor Profile",
  "status": "active",
  "description": "Identifies a tumor that has not been removed from the body. Whenever possible, a single resource conforming to this profile will be used to track a tumor over time (as opposed to creating new Tumor-conforming BodyStructure resources each time that tumor is measured). Use HumanSpecimen to represent the tumor after removal from the body. \nNote that the required code for morphology used in STU2 is now inactive.  A new code has been specified and SHOULD be used, but the old code remains conformant.",
  "fhirVersion": "4.0.1",
  "mapping": [
    {
      "identity": "rim",
      "uri": "http://hl7.org/v3",
      "name": "RIM Mapping"
    },
    {
      "identity": "openehr",
      "uri": "http://openehr.org",
      "name": "Open EHR Archetype Mapping"
    },
    {
      "identity": "w5",
      "uri": "http://hl7.org/fhir/fivews",
      "name": "FiveWs Pattern Mapping"
    },
    {
      "identity": "v2",
      "uri": "http://hl7.org/v2",
      "name": "HL7 v2 Mapping"
    }
  ],
  "kind": "resource",
  "abstract": false,
  "type": "BodyStructure",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/BodyStructure",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "BodyStructure.extension",
        "path": "BodyStructure.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        },
        "mustSupport": true
      },
      {
        "id": "BodyStructure.extension:relatedCondition",
        "path": "BodyStructure.extension",
        "sliceName": "relatedCondition",
        "short": "Reference to cancer condition associated with this tumor",
        "definition": "Associates this tumor with a cancer condition. This could be a causal association (e.g., this is believed to be the primary tumor causing the cancer) or a different type of relationship (e.g., this tumor is a metastasis)",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-related-condition"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "BodyStructure.extension:relatedCondition.value[x]",
        "path": "BodyStructure.extension.value[x]",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/core/StructureDefinition/us-core-condition-problems-health-concerns"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "BodyStructure.identifier",
        "path": "BodyStructure.identifier",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "type"
            }
          ],
          "rules": "open",
          "description": "Slice containing at least one tumor identifier"
        },
        "short": "Stable identifier(s) for this tumor",
        "definition": "Stable identifier(s) for this specific tumor. The identifiers MUST be unique within the context of the referenced `CancerPatient`.",
        "comment": "If applicable, an identifier should correspond to the physical tag inserted into the tumor during a procedure that is used for tracking the tumor by radiology and pathology.",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "BodyStructure.identifier:bodyStructureIdentifier",
        "path": "BodyStructure.identifier",
        "sliceName": "bodyStructureIdentifier",
        "short": "A persistent identifier of this tumor.",
        "definition": "A persistent identifier used to identify and track the tumor over time. The identifier must be unique in the context of the patient.",
        "min": 1,
        "max": "*",
        "type": [
          {
            "code": "Identifier",
            "profile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-body-structure-identifier"
            ]
          }
        ]
      },
      {
        "id": "BodyStructure.morphology",
        "path": "BodyStructure.morphology",
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-tumor-morphology-code-vs",
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/elementdefinition-maxValueSet",
              "valueCanonical": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-tumor-morphology-code-max-vs"
            }
          ]
        }
      },
      {
        "id": "BodyStructure.location",
        "path": "BodyStructure.location",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-cancer-body-location-vs"
        }
      },
      {
        "id": "BodyStructure.locationQualifier",
        "path": "BodyStructure.locationQualifier",
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-body-location-and-laterality-qualifier-vs"
        }
      },
      {
        "id": "BodyStructure.patient",
        "path": "BodyStructure.patient",
        "definition": "The patient associated with this tumor.",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-cancer-patient"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
