          "strength": "extensible",
          "valueSet": "http://hl7.org/fhir/us/mcode/ValueSet/mcode-cancer-disorder-vs"
        }
      },
      {
        "id": "Procedure.reasonReference",
        "path": "Procedure.reasonReference",
