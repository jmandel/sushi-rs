{
  "resourceType": "StructureDefinition",
  "id": "profile-pas-inquiry-response-bundle",
  "url": "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-pas-inquiry-response-bundle",
  "name": "PASInquiryResponseBundle",
  "title": "PAS Inquiry Response Bundle",
  "status": "active",
  "description": "PAS constraints on Bundle resource ensuring that a claim inquiry response resource is present and that non-supported elements are not.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Bundle",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Bundle",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Bundle",
        "path": "Bundle",
        "constraint": [
          {
            "key": "ClaimResponseFirst",
            "severity": "error",
            "human": "A Prior Authorization Response Bundle must have the PAS Response as the first resource",
            "expression": "entry.first().resource is ClaimResponse",
            "source": "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-pas-inquiry-response-bundle"
          }
        ]
      },
      {
        "id": "Bundle.type",
        "path": "Bundle.type",
        "fixedCode": "collection"
      },
      {
        "id": "Bundle.timestamp",
        "path": "Bundle.timestamp",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry",
        "path": "Bundle.entry",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "resource"
            }
          ],
          "rules": "open",
          "description": "Slice different resources included in the bundle"
        },
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.fullUrl",
        "path": "Bundle.entry.fullUrl",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.resource",
        "path": "Bundle.entry.resource",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.search",
        "path": "Bundle.entry.search",
        "max": "0"
      },
      {
        "id": "Bundle.entry.request",
        "path": "Bundle.entry.request",
        "max": "0"
      },
      {
        "id": "Bundle.entry.response",
        "path": "Bundle.entry.response",
        "max": "0"
      },
      {
        "id": "Bundle.entry:ClaimResponse",
        "path": "Bundle.entry",
        "sliceName": "ClaimResponse",
        "min": 0,
        "max": "*",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:ClaimResponse.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "ClaimResponse",
            "profile": [
              "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-claiminquiryresponse"
            ]
          }
        ]
      }
    ]
  }
}
