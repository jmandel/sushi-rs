{
  "resourceType": "StructureDefinition",
  "id": "profile-pas-request-bundle",
  "url": "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-pas-request-bundle",
  "name": "PASRequestBundle",
  "title": "PAS Request Bundle",
  "status": "active",
  "description": "PAS constraints on Bundle resource ensuring that a claim/claim update resource is present and that non-supported elements are not.",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Bundle",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Bundle",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Bundle",
        "path": "Bundle",
        "constraint": [
          {
            "key": "ClaimFirst",
            "severity": "error",
            "human": "A Prior Authorization Bundle must have the PAS Request as the first resource",
            "expression": "entry.first().resource is Claim",
            "source": "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-pas-request-bundle"
          }
        ]
      },
      {
        "id": "Bundle.identifier",
        "path": "Bundle.identifier",
        "short": "Submitted Transaction Identifier - this number will be assigned by the originator or sender to identify the transaction within the sender's business application system",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.type",
        "path": "Bundle.type",
        "patternCode": "collection"
      },
      {
        "id": "Bundle.timestamp",
        "path": "Bundle.timestamp",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry",
        "path": "Bundle.entry",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "resource"
            }
          ],
          "rules": "open",
          "description": "Slice different resources included in the bundle"
        },
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.fullUrl",
        "path": "Bundle.entry.fullUrl",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.resource",
        "path": "Bundle.entry.resource",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Bundle.entry.search",
        "path": "Bundle.entry.search",
        "max": "0"
      },
      {
        "id": "Bundle.entry.request",
        "path": "Bundle.entry.request",
        "max": "0"
      },
      {
        "id": "Bundle.entry.response",
        "path": "Bundle.entry.response",
        "max": "0"
      },
      {
        "id": "Bundle.entry:Claim",
        "path": "Bundle.entry",
        "sliceName": "Claim",
        "min": 1,
        "max": "2",
        "mustSupport": true
      },
      {
        "id": "Bundle.entry:Claim.resource",
        "path": "Bundle.entry.resource",
        "type": [
          {
            "code": "Claim",
            "profile": [
              "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-claim-update",
              "http://hl7.org/fhir/us/davinci-pas/StructureDefinition/profile-claim"
            ]
          }
        ]
      }
    ]
  }
}
