              "path": "url"
            }
          ],
          "rules": "open"
        },
        "mustSupport": true
      },
      {
        "id": "Encounter.diagnosis.extension:sliceEncounterDiagnosisTrigger",
        "path": "Encounter.diagnosis.extension",
        "sliceName": "sliceEncounterDiagnosisTrigger",
