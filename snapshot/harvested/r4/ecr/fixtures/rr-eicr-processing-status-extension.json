{
  "resourceType": "StructureDefinition",
  "id": "rr-eicr-processing-status-extension",
  "url": "http://hl7.org/fhir/us/ecr/StructureDefinition/rr-eicr-processing-status-extension",
  "name": "RREicrProcessingStatusExtension",
  "title": "eICR Processing Status Extension",
  "status": "active",
  "description": "This Extension profile represents the eICR processing status.",
  "fhirVersion": "4.0.1",
  "kind": "complex-type",
  "abstract": false,
  "context": [
    {
      "expression": "Composition.section",
