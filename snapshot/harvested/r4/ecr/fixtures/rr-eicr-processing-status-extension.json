    }
  ],
  "type": "Extension",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Extension",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Extension",
        "path": "Extension",
        "short": "eICR Processing Status",
        "definition": "This extension indicates the eICR processing status. If the eICR was not processed or was processed with a warning, the reason will be contained in the eICR Processing Status Reason. If there is any output from a validator, that output will be contained in the eICR Validation Output.\n\nIf any of the trigger codes used to generate the eICR are from an outdated version of the RCTC or the codes are marked as inactive in the latest version of the RCTC, these are flagged and and the eICR Processing Status Reason Detail will hold the details of the outdated and expected versions of the RCTC."
      },
      {
        "id": "Extension.extension",
        "path": "Extension.extension",
        "min": 1
      },
      {
        "id": "Extension.extension:eICRProcessingStatus",
        "path": "Extension.extension",
        "sliceName": "eICRProcessingStatus",
        "min": 1,
        "max": "1"
      },
      {
        "id": "Extension.extension:eICRProcessingStatus.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:eICRProcessingStatus.url",
        "path": "Extension.extension.url",
        "fixedUri": "eICRProcessingStatus"
      },
      {
        "id": "Extension.extension:eICRProcessingStatus.value[x]",
        "path": "Extension.extension.value[x]",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/us/ecr/StructureDefinition/rr-eicr-processing-status-observation"
            ]
          }
        ]
      },
      {
        "id": "Extension.extension:eICRValidationOutput",
        "path": "Extension.extension",
        "sliceName": "eICRValidationOutput",
        "definition": "Contains eICR validation output - this could be the actual output from a validator, or a link to a validation output file",
        "min": 0,
        "max": "*"
      },
      {
        "id": "Extension.extension:eICRValidationOutput.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:eICRValidationOutput.url",
        "path": "Extension.extension.url",
        "fixedUri": "eICRValidationOutput"
      },
      {
        "id": "Extension.extension:eICRValidationOutput.value[x]",
        "path": "Extension.extension.value[x]",
        "min": 1,
        "type": [
          {
            "code": "markdown"
          },
          {
            "code": "string"
          },
          {
            "code": "Attachment"
          }
        ]
      },
      {
        "id": "Extension.url",
