        "mustSupport": false
      },
      {
        "id": "Device.type",
        "path": "Device.type",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "extensible",
          "description": "Codes to identify medical devices",
          "valueSet": "http://hl7.org/fhir/ValueSet/device-kind"
