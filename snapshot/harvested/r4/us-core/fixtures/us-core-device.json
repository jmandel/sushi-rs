          }
        ],
        "path": "Device.distinctIdentifier",
        "short": "𝗔𝗗𝗗𝗜𝗧𝗜𝗢𝗡𝗔𝗟 𝗨𝗦𝗖𝗗𝗜: The distinct identification string",
        "mustSupport": false
      },
      {
