            "valueBoolean": true
          }
        ],
        "path": "Device.manufactureDate",
        "short": "𝗔𝗗𝗗𝗜𝗧𝗜𝗢𝗡𝗔𝗟 𝗨𝗦𝗖𝗗𝗜: Date when the device was made",
        "mustSupport": false
      },
      {
        "id": "Device.expirationDate",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/core/StructureDefinition/uscdi-requirement",
            "valueBoolean": true
          }
        ],
        "path": "Device.expirationDate",
        "short": "𝗔𝗗𝗗𝗜𝗧𝗜𝗢𝗡𝗔𝗟 𝗨𝗦𝗖𝗗𝗜: Date and time of expiry of this device (if applicable)",
        "mustSupport": false
      },
      {
        "id": "Device.lotNumber",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/core/StructureDefinition/uscdi-requirement",
            "valueBoolean": true
          }
        ],
        "path": "Device.lotNumber",
        "short": "𝗔𝗗𝗗𝗜𝗧𝗜𝗢𝗡𝗔𝗟 𝗨𝗦𝗖𝗗𝗜: Lot number of manufacture",
