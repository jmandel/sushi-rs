              "type": "value",
              "path": "type"
            }
          ],
          "rules": "open"
        },
        "mustSupport": true,
        "mapping": [
          {
            "identity": "DocumentEntry-Mapping",
            "map": "DocumentEntry.entryUUID"
          }
        ]
      },
      {
        "id": "DocumentReference.identifier:entryUUID",
        "path": "DocumentReference.identifier",
        "sliceName": "entryUUID",
        "short": "Business identifier for the DocumentReference",
        "definition": "The Business identifier for the DocumentReference which maps to the DocumentEntry.entryUUID in XDS. This is used to refer to the DocumentReference itself as a record of the Document's metadata, as opposed to the UniqueId element which identifies the document which is pointed at by the document reference.",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Identifier",
            "profile": [
              "https://profiles.ihe.net/ITI/MHD/StructureDefinition/IHE.MHD.EntryUUID.Identifier"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "DocumentReference.identifier:uniqueId",
        "path": "DocumentReference.identifier",
        "sliceName": "uniqueId",
        "short": "Unique identifier for the referenced Document",
        "definition": "The unique identifier for the referenced Document which maps to the DocumentEntry.uniqueId in XDS. This is used to identify the document which is pointed at by the DocumentReference Resource, as opposed to the entryUUID element which identifies the DocumentReference Resource itself. If this is present, then the identifier SHALL be the same as the one found in masterIdentifier.",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Identifier",
            "profile": [
              "https://profiles.ihe.net/ITI/MHD/StructureDefinition/IHE.MHD.UniqueIdIdentifier"
            ]
          }
        ],
        "mustSupport": true
      },
      {
