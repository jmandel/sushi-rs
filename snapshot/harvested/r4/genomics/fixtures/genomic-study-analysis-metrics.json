          {
            "code": "Quantity",
            "profile": [
              "http://hl7.org/fhir/StructureDefinition/SimpleQuantity"
            ]
          }
        ]
      },
      {
        "id": "Extension.extension:metrics-description",
        "path": "Extension.extension",
        "sliceName": "metrics-description",
